#!/usr/bin/env bash

set -euo pipefail

repository_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repository_root"

npm ci --cache "$repository_root/.cache/npm" --ignore-scripts --no-audit --no-fund

markdown_files=()
while IFS= read -r -d '' markdown_file; do
  markdown_files[${#markdown_files[@]}]="$markdown_file"
done < <(node tooling/check.mjs --list-markdown)
if ((${#markdown_files[@]} > 0)); then
  ./node_modules/.bin/markdownlint-cli2 "${markdown_files[@]}"
fi

node tooling/check.mjs
./tooling/preflight
./tooling/preflight --twin
expected_vendor_inventory() {
  awk '{print $2}' tooling/vendor/opskarta/UPSTREAM.sha256
  printf '%s\n' \
    tooling/vendor/opskarta/UPSTREAM.md \
    tooling/vendor/opskarta/UPSTREAM.sha256
}

actual_vendor_inventory() {
  find tooling/vendor/opskarta \( -type f -o -type l \) -print
}

if ! diff -u \
  <(expected_vendor_inventory | LC_ALL=C sort) \
  <(actual_vendor_inventory | LC_ALL=C sort); then
  echo "Vendored OpsKarta inventory differs from the closed manifest" >&2
  exit 1
fi
shasum -a 256 --check tooling/vendor/opskarta/UPSTREAM.sha256
./tooling/opskarta --strict docs/planning/graphtruth.plan.yaml
node --test \
  tooling/codex-author-call-qualification-v1.test.mjs \
  tooling/codex-evaluation-freeze.test.mjs \
  tooling/codex-evaluation-freeze-v2.test.mjs \
  tooling/codex-g1-review.test.mjs \
  tooling/codex-sandbox-preflight.test.mjs \
  tooling/check.test.mjs \
  tooling/private-pack-lock.test.mjs \
  tooling/project-verbatim-rst.test.mjs \
  tooling/preflight.test.mjs \
  tooling/opskarta.test.mjs \
  runtime/lib.test.mjs \
  runtime/replay.test.mjs
